{
  "name": "syncwatch",
  "version": "1.0.0",
  "description": "syncwatch-root",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/syncwatch-server",
    "packages/syncwatch-locales",
    "packages/syncwatch-extension",
    "packages/syncwatch-types"
  ],
  "scripts": {
    "lint": "npx @biomejs/biome format --write .",
    "compile": "tsc --build tsconfig.build.json",
    "app:extension": "npm run build -w syncwatch-extension",
    "app:extension:dev": "npm run dev -w syncwatch-extension",
    "app:package": "npm run zip -w syncwatch-extension",
    "app:relay": "npm run start:dev -w syncwatch-server"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  },
  "dependencies": {
    "typescript": "^5.8.3"
  }
}
